# ECOS local development configuration example. Do not put real secrets here.
ECOS_NAME=ECOS
ECOS_SERVICE_NAME=ecos-backend
ECOS_VERSION=0.1.0
ECOS_ENVIRONMENT=development
ECOS_LOG_LEVEL=INFO
ECOS_DATABASE_URL=postgresql://ecos:ecos@postgres:5432/ecos
ECOS_SESSION_REPOSITORY=fake
ECOS_MEMORY_REPOSITORY=fake
ECOS_OBSERVABILITY_REPOSITORY=memory
ECOS_KNOWLEDGE_REPOSITORY=memory
ECOS_SECURITY_REPOSITORY=memory
ECOS_OPERATIONAL_REPOSITORY=memory
ECOS_AUTH_TOKEN_SECRET=development-only-auth-secret-change-me-000000
ECOS_AUTH_TOKEN_TTL_MINUTES=60
ECOS_AUTH_ISSUER=ecos.local
ECOS_AUTH_AUDIENCE=ecos.api
ECOS_AUTH_DEMO_ENABLED=true
ECOS_DEMO_SEED_ENABLED=true
ECOS_WEB_COOKIE_NAME=ecos_session
ECOS_CSRF_COOKIE_NAME=ecos_csrf
ECOS_CSRF_HEADER_NAME=X-CSRF-Token
ECOS_FRONTEND_STATIC_DIR=frontend/dist
ECOS_METRICS_ENABLED=true
ECOS_AI_PROVIDER=fake
ECOS_OPENAI_API_KEY=
ECOS_OPENAI_MODEL=gpt-4.1-mini
ECOS_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ECOS_OPENAI_TIMEOUT_SECONDS=30
ECOS_OPENAI_MAX_RETRIES=2
ECOS_REDIS_URL=redis://redis:6379/0
ECOS_PGADMIN_EMAIL=admin@example.local
ECOS_PGADMIN_PASSWORD=change-me-development-only
ECOS_POSTGRES_PASSWORD=ecos
