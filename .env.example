# ECOS local development configuration example. Do not put real secrets here.
ECOS_NAME=ECOS
ECOS_SERVICE_NAME=ecos-backend
ECOS_VERSION=0.1.0
ECOS_ENVIRONMENT=development
ECOS_LOG_LEVEL=INFO
ECOS_DATABASE_URL=postgresql://ecos:ecos@postgres:5432/ecos
ECOS_SESSION_REPOSITORY=fake
ECOS_REDIS_URL=redis://redis:6379/0
ECOS_PGADMIN_EMAIL=admin@example.local
ECOS_PGADMIN_PASSWORD=change-me-development-only
